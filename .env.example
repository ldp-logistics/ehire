# Copy to .env and fill in values. Do not commit .env.

# Database
# DATABASE_URL=postgresql://...

# Auth
# JWT_SECRET=...
# Optional: override break-glass admin email (default ehire@ldplogistics.com — matches seed / migration rename).
# BREAK_GLASS_PRIMARY_EMAIL=other@tenant.onmicrosoft.com

# Microsoft SSO (Sign in with Microsoft — main Azure app)
# MS_CLIENT_ID=...
# MS_CLIENT_SECRET=...
# MS_TENANT_ID=...
# MS_REDIRECT_URI=http://localhost:5000/api/auth/microsoft/callback

# Interview calendar — separate delegated Azure app (scheduler as Outlook/Teams organizer).
# Register redirect URI: https://your-domain.com/api/auth/microsoft/calendar/callback
# API permissions (delegated only): Calendars.ReadWrite, offline_access — then Grant admin consent.
# MS_DELEGATED_CLIENT_ID=...
# MS_DELEGATED_CLIENT_SECRET=...   ← secret *Value* from Azure (NOT the Secret ID GUID)
# MS_DELEGATED_REDIRECT_URI=https://your-domain.com/api/auth/microsoft/calendar/callback
# Outlook event start/end sent in US Eastern (scheduler form may use PKT); override if needed:
# INTERVIEW_CALENDAR_OUTLOOK_IANA=America/New_York

# Auto email interviewers for feedback when a round ends (same template as HR "Send Reminder").
# INTERVIEW_FEEDBACK_REMINDER_CRON=false

# Teams app-only Graph (background / shared mailbox tests — not used for SSO login).
# TEAMS_MEETING_ORGANIZER_EMAIL=hr@company.com
# TEAMS_GRAPH_ENABLED=true

# FreshTeam job migration (admin API key from FreshTeam; used by POST /api/recruitment/migrate-freshteam-jobs)
# FRESHTEAM_DOMAIN=ldplogistics
# FRESHTEAM_API_KEY=your_api_key_here
# Rate limit: requests per minute. Check response header x-ratelimit-total (e.g. 60). Default 55 to stay under 60.
# FRESHTEAM_REQUESTS_PER_MINUTE=55
# Leave request migration (POST /api/leave/migrate-from-freshteam): only import time_offs with start_date >= this (YYYY-MM-DD). Default 2026-01-01.
# FRESHTEAM_LEAVE_MIGRATE_FROM=2026-01-01

# Resend.com – recruitment application emails (two-way thread). Create API key at https://resend.com/api-keys, verify domain at https://resend.com/domains.
# RESEND_API_KEY=re_xxx
# RESEND_FROM=Recruitment <careers@hr.ldplogistics.com>
# For two-way thread: inbound domain (e.g. hr.ldplogistics.com). When RESEND_REPLY_TO_CLEAN is not set, Reply-To is reply+<applicationId>@ this domain so webhook matches replies. When RESEND_REPLY_TO_CLEAN=true, Reply-To is careers@ (clean) and we match by In-Reply-To (requires Resend to preserve our Message-ID).
# RESEND_INBOUND_REPLY_DOMAIN=hr.ldplogistics.com
# RESEND_REPLY_TO_CLEAN=true

# Public SPA base URL (no trailing slash), e.g. https://ehire.example.com — NOT the SendGrid inbound webhook URL.
# Used for {{app_url}} in notification templates, offer-response links, and recruitment links in emails.
# APP_URL=https://your-app.example.com

# Recruitment / offer PDF: experimental literal {{…}} overlay on Word-exported PDFs (usually looks bad — leave off).
# OFFER_PDF_REPLACE_LITERAL_BRACES=true

# Recruitment / e-sign: log merge variables and template branch (mergeOfferTemplate / buildOfferVariables).
# OFFER_DEBUG_MERGE=1

# Email notification display name / footer label (branding colors & logo are managed in Settings → Email notifications)
# COMPANY_NAME=LDP Logistics
# SOFTWARE_NAME=eHire

# Per-module "From" address (optional, falls back to EMAIL_FROM_NOTIFICATIONS then EMAIL_FROM)
# EMAIL_FROM_LEAVE=HR Leave <leave@company.com>
# EMAIL_FROM_RECRUITMENT=Recruitment <careers@company.com>

# Attendance auto-checkout job: POST /api/attendance/internal/auto-checkout-sweep with header x-attendance-cron-secret
# ATTENDANCE_CRON_SECRET=long-random-string

# HR email digest: employees with login who have not clocked in, 1 hour after org work-day start (org_timesheet_policy.policy_timezone + work_day_start). Once per work day if anyone is missing. Recipients: users with role hr or limited_hr (plus optional extras below). Requires SENDGRID_API_KEY + migration 0102.
# ENABLE_MISSING_CHECKIN_HR_ALERT=true
# MISSING_CHECKIN_HR_ALERT_EXTRA_EMAILS=ops@company.com,another@company.com

# Leave accrual cron (Earned Leave + monthly) — like FreshTeam auto-accrual. Off unless explicitly enabled.
# ENABLE_LEAVE_ACCRUAL_CRON=true
# Fallback IANA timezone if HR has not chosen one under Settings → Email notifications → Timezone for emails.
# Allowed in UI: Asia/Karachi (PKT), America/New_York (EST/EDT), Asia/Kolkata (IST).
# DEFAULT_TIMEZONE=Asia/Karachi
# Optional: node-cron expression. Default: 00:00 on the 1st of each month in DEFAULT_TIMEZONE
# LEAVE_ACCRUAL_CRON=0 0 1 * *

# Scheduled recruitment emails (e.g. rejection notice at a chosen date/time). Cron runs every minute (UTC). Set false to disable worker only.
# SCHEDULED_RECRUITMENT_EMAIL_CRON=false

# Anthropic Claude – LinkedIn job post generator in recruitment module. Get key at https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=

# Client (Vite) — public docs site linked from in-app Software Guide
# VITE_EHIRE_DOCS_URL=https://ehire-docs.ldplogistics.com
